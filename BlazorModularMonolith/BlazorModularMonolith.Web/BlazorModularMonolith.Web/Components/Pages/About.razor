@page "/about"
@rendermode InteractiveServer

<PageTitle>About</PageTitle>

<div class="about-container">
    <div class="card shadow-sm">
        <div class="card-body p-4">
            <h1 class="page-title"><i class="bi bi-info-circle-fill me-2"></i>About</h1>
            <p class="lead">Address Management System — a modular monolith built with Blazor and .NET 10.</p>

            <hr />

            <div class="row g-4 mt-1">
                <div class="col-md-6">
                    <h5><i class="bi bi-stack me-2 text-primary"></i>Technology Stack</h5>
                    <ul class="list-unstyled ms-3">
                        <li><i class="bi bi-check2 text-success me-2"></i>ASP.NET Core Minimal API (.NET 10)</li>
                        <li><i class="bi bi-check2 text-success me-2"></i>Blazor Web App (Interactive Server)</li>
                        <li><i class="bi bi-check2 text-success me-2"></i>JWT Bearer Authentication</li>
                        <li><i class="bi bi-check2 text-success me-2"></i>Modular Monolith Architecture</li>
                        <li><i class="bi bi-check2 text-success me-2"></i>File-based JSON persistence</li>
                        <li><i class="bi bi-check2 text-success me-2"></i>API Versioning with Scalar UI</li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <h5><i class="bi bi-box-seam me-2 text-primary"></i>Modules</h5>
                    <ul class="list-unstyled ms-3">
                        <li><i class="bi bi-people-fill text-info me-2"></i>People Management</li>
                        <li><i class="bi bi-building text-info me-2"></i>Business Management</li>
                        <li><i class="bi bi-geo-alt-fill text-info me-2"></i>Address Management</li>
                        <li><i class="bi bi-shield-lock-fill text-info me-2"></i>Authentication &amp; Authorization</li>
                        <li><i class="bi bi-person-gear text-info me-2"></i>User Administration</li>
                    </ul>
                </div>
            </div>

            <hr />

            <h5><i class="bi bi-key-fill me-2 text-primary"></i>Default Credentials</h5>
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card border-danger">
                        <div class="card-body py-2">
                            <h6 class="card-title mb-1"><span class="badge bg-danger me-1">Admin</span> Full access</h6>
                            <code>admin / Admin123!</code>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-primary">
                        <div class="card-body py-2">
                            <h6 class="card-title mb-1"><span class="badge bg-primary me-1">User</span> Read-only access</h6>
                            <code>user / User123!</code>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .about-container {
        max-width: 900px;
        margin: 0 auto;
    }
</style>
