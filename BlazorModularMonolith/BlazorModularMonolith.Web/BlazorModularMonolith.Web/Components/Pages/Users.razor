@page "/users"
@rendermode InteractiveServer
@using BlazorModularMonolith.Web.Common
@using BlazorModularMonolith.Web.Models
@using BlazorModularMonolith.Web.Services
@inject IUserApiService UserService
@inject IJSRuntime JSRuntime

<PageTitle>User Management</PageTitle>

<AuthorizeView Role="Admin">
    <h1 class="page-title"><i class="bi bi-people-fill me-2"></i>User Management</h1>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger alert-dismissible" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@_errorMessage
            <button type="button" class="btn-close" @onclick="() => _errorMessage = string.Empty"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(_successMessage))
    {
        <div class="alert alert-success alert-dismissible" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@_successMessage
            <button type="button" class="btn-close" @onclick="() => _successMessage = string.Empty"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Users</h5>
            <button class="btn btn-primary btn-sm" @onclick="ShowCreateForm">
                <i class="bi bi-person-plus-fill me-1"></i> Add User
            </button>
        </div>
        <div class="card-body p-0">
            @if (_isLoading)
            {
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Username</th>
                                <th>Email</th>
                                <th>Roles</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th>Last Login</th>
                                <th class="actions-col">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in _users)
                            {
                                <tr>
                                    <td><i class="bi bi-person-circle me-1 text-secondary"></i>@user.Username</td>
                                    <td>@user.Email</td>
                                    <td>
                                        @foreach (var role in user.Roles)
                                        {
                                            <span class="badge @(role == "Admin" ? "bg-danger" : "bg-primary") me-1">@role</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @(user.IsActive ? "bg-success" : "bg-secondary")">
                                            @(user.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>@user.CreatedAt.ToLocalTime().ToString("d")</td>
                                    <td>@(user.LastLoginAt.HasValue ? user.LastLoginAt.Value.ToLocalTime().ToString("g") : "Never")</td>
                                    <td class="actions-col">
                                        <div class="action-buttons">
                                            <button class="btn-action btn-action--edit" @onclick="() => ShowEditForm(user)">
                                                <i class="bi bi-pencil-fill"></i> Edit
                                            </button>
                                            <button class="btn-action btn-action--delete" @onclick="() => DeleteUser(user.Id)">
                                                <i class="bi bi-trash-fill"></i> Delete
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (!_users.Any())
                {
                    <p class="text-center text-muted py-4">No users found.</p>
                }
            }
        </div>
    </div>
</AuthorizeView>

@if (_showCreateModal)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-person-plus-fill me-2"></i>Create User</h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="_createModel" OnValidSubmit="CreateUser">
                        <DataAnnotationsValidator />
                        <div class="mb-3">
                            <label class="form-label">Username</label>
                            <InputText class="form-control" @bind-Value="_createModel.Username" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <InputText type="email" class="form-control" @bind-Value="_createModel.Email" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <InputText type="password" class="form-control" @bind-Value="_createModel.Password" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Roles</label>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="createRoleUser"
                                       checked="@_createModel.Roles.Contains(RoleUser)"
                                       @onchange="e => ToggleRole(_createModel.Roles, RoleUser, (bool)e.Value!)" />
                                <label class="form-check-label" for="createRoleUser">User</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="createRoleAdmin"
                                       checked="@_createModel.Roles.Contains(RoleAdmin)"
                                       @onchange="e => ToggleRole(_createModel.Roles, RoleAdmin, (bool)e.Value!)" />
                                <label class="form-check-label" for="createRoleAdmin">Admin</label>
                            </div>
                        </div>
                        <div class="d-flex gap-2 justify-content-end">
                            <button type="button" class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
                            <button type="submit" class="btn btn-primary" disabled="@_isSaving">
                                @if (_isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Create
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@if (_showEditModal && _editModel != null)
{
    <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-pencil-fill me-2"></i>Edit User — @_editingUsername</h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="_editModel" OnValidSubmit="UpdateUser">
                        <DataAnnotationsValidator />
                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <InputText type="email" class="form-control" @bind-Value="_editModel.Email" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Roles</label>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="editRoleUser"
                                       checked="@_editModel.Roles.Contains(RoleUser)"
                                       @onchange="e => ToggleRole(_editModel.Roles, RoleUser, (bool)e.Value!)" />
                                <label class="form-check-label" for="editRoleUser">User</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="editRoleAdmin"
                                       checked="@_editModel.Roles.Contains(RoleAdmin)"
                                       @onchange="e => ToggleRole(_editModel.Roles, RoleAdmin, (bool)e.Value!)" />
                                <label class="form-check-label" for="editRoleAdmin">Admin</label>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="form-check form-switch">
                                <InputCheckbox class="form-check-input" id="editIsActive" @bind-Value="_editModel.IsActive" />
                                <label class="form-check-label" for="editIsActive">Active</label>
                            </div>
                        </div>
                        <div class="d-flex gap-2 justify-content-end">
                            <button type="button" class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
                            <button type="submit" class="btn btn-primary" disabled="@_isSaving">
                                @if (_isSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                                Save Changes
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .page-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 1.5rem;
    }

    .actions-col {
        width: 160px;
        white-space: nowrap;
    }

    .action-buttons {
        display: flex;
        gap: 0.5rem;
        justify-content: flex-end;
        align-items: center;
    }

    .btn-action {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.4rem 0.85rem;
        font-size: 0.82rem;
        font-weight: 600;
        border: none;
        border-radius: 0.4rem;
        cursor: pointer;
        transition: opacity 0.15s, transform 0.1s;
        white-space: nowrap;
    }

    .btn-action:hover {
        opacity: 0.88;
        transform: translateY(-1px);
    }

    .btn-action:active {
        transform: translateY(0);
    }

    .btn-action--edit {
        background: #4f46e5;
        color: #fff;
    }

    .btn-action--edit:hover {
        background: #4338ca;
    }

    .btn-action--delete {
        background: #ef4444;
        color: #fff;
    }

    .btn-action--delete:hover {
        background: #dc2626;
    }
</style>

@code {
    private List<UserModel> _users = [];
    private bool _isLoading = true;
    private bool _isSaving;
    private string _errorMessage = string.Empty;
    private string _successMessage = string.Empty;

    private bool _showCreateModal;
    private bool _showEditModal;
    private Guid _editingUserId;
    private string _editingUsername = string.Empty;
    private CreateUserModel _createModel = new();
    private UpdateUserModel? _editModel;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        _isLoading = true;
        var result = await UserService.GetAllUsersAsync();
        if (result.IsSuccess)
            _users = result.Value!;
        else
            _errorMessage = result.Error!;
        _isLoading = false;
    }

    private void ShowCreateForm()
    {
        _createModel = new CreateUserModel { Roles = ["User"] };
        _showCreateModal = true;
    }

    private void ShowEditForm(UserModel user)
    {
        _editingUserId = user.Id;
        _editingUsername = user.Username;
        _editModel = new UpdateUserModel
        {
            Email = user.Email,
            Roles = [.. user.Roles],
            IsActive = user.IsActive
        };
        _showEditModal = true;
    }

    private void CloseModals()
    {
        _showCreateModal = false;
        _showEditModal = false;
    }

    private async Task CreateUser()
    {
        _isSaving = true;
        var result = await UserService.CreateUserAsync(_createModel);
        _isSaving = false;

        if (result.IsSuccess)
        {
            _successMessage = $"User '{result.Value!.Username}' created successfully.";
            CloseModals();
            await LoadUsers();
        }
        else
        {
            _errorMessage = result.Error!;
        }
    }

    private async Task UpdateUser()
    {
        if (_editModel is null) return;
        _isSaving = true;
        var result = await UserService.UpdateUserAsync(_editingUserId, _editModel);
        _isSaving = false;

        if (result.IsSuccess)
        {
            _successMessage = $"User '{_editingUsername}' updated successfully.";
            CloseModals();
            await LoadUsers();
        }
        else
        {
            _errorMessage = result.Error!;
        }
    }

    private async Task DeleteUser(Guid id)
    {
        var user = _users.FirstOrDefault(u => u.Id == id);
        if (user is null) return;

        if (!await JSRuntime.InvokeAsync<bool>("confirm", $"Delete user '{user.Username}'? This cannot be undone."))
            return;

        var result = await UserService.DeleteUserAsync(id);
        if (result.IsSuccess)
        {
            _successMessage = $"User '{user.Username}' deleted.";
            await LoadUsers();
        }
        else
        {
            _errorMessage = result.Error!;
        }
    }

    private const string RoleUser = "User";
    private const string RoleAdmin = "Admin";

    private static void ToggleRole(List<string> roles, string role, bool add)
    {
        if (add && !roles.Contains(role)) roles.Add(role);
        else if (!add) roles.Remove(role);
    }
}
