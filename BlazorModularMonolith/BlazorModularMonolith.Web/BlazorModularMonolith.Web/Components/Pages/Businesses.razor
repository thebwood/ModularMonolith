@page "/businesses"
@rendermode InteractiveServer
@inject BusinessesViewModel ViewModel
@inject IAddressApiService AddressService
@using BlazorModularMonolith.Web.ViewModels
@using BlazorModularMonolith.Web.Models
@using BlazorModularMonolith.Web.Services

<PageTitle>Business Management</PageTitle>

<h1>Business Management</h1>

@if (ViewModel.HasError)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @ViewModel.ErrorMessage
        <button type="button" class="btn-close" @onclick="() => ViewModel.ClearError()"></button>
    </div>
}

@if (ViewModel.IsBusy)
{
    <div class="text-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="mb-3">
        <button class="btn btn-primary" @onclick="ShowCreateForm">
            <i class="bi bi-plus-circle"></i> Add New Business
        </button>
    </div>

    @if (ViewModel.IsCreating)
    {
        <div class="card mb-3">
            <div class="card-header">
                <h5>Create New Business</h5>
            </div>
            <div class="card-body">
                <EditForm Model="@ViewModel.NewBusiness" OnValidSubmit="CreateBusiness">
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="ViewModel.NewBusiness.Name" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Tax ID</label>
                            <InputText class="form-control" @bind-Value="ViewModel.NewBusiness.TaxId" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Business Type</label>
                            <InputSelect class="form-select" @bind-Value="ViewModel.NewBusiness.Type">
                                <option value="@BusinessType.SoleProprietorship">Sole Proprietorship</option>
                                <option value="@BusinessType.Partnership">Partnership</option>
                                <option value="@BusinessType.Corporation">Corporation</option>
                                <option value="@BusinessType.LLC">LLC</option>
                                <option value="@BusinessType.NonProfit">Non-Profit</option>
                                <option value="@BusinessType.Other">Other</option>
                            </InputSelect>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <InputText type="email" class="form-control" @bind-Value="ViewModel.NewBusiness.Email" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Phone Number</label>
                            <InputText class="form-control" @bind-Value="ViewModel.NewBusiness.PhoneNumber" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Website</label>
                        <InputText type="url" class="form-control" @bind-Value="ViewModel.NewBusiness.Website" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">Save</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => ViewModel.CancelEdit()">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @if (ViewModel.IsEditing && ViewModel.SelectedBusiness != null)
    {
        <div class="card mb-3">
            <div class="card-header">
                <h5>Edit Business</h5>
            </div>
            <div class="card-body">
                <EditForm Model="@ViewModel.EditBusiness" OnValidSubmit="UpdateBusiness">
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <InputText class="form-control" @bind-Value="ViewModel.EditBusiness.Name" />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Tax ID</label>
                            <InputText class="form-control" @bind-Value="ViewModel.EditBusiness.TaxId" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Business Type</label>
                            <InputSelect class="form-select" @bind-Value="ViewModel.EditBusiness.Type">
                                <option value="@BusinessType.SoleProprietorship">Sole Proprietorship</option>
                                <option value="@BusinessType.Partnership">Partnership</option>
                                <option value="@BusinessType.Corporation">Corporation</option>
                                <option value="@BusinessType.LLC">LLC</option>
                                <option value="@BusinessType.NonProfit">Non-Profit</option>
                                <option value="@BusinessType.Other">Other</option>
                            </InputSelect>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <InputText type="email" class="form-control" @bind-Value="ViewModel.EditBusiness.Email" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Phone Number</label>
                            <InputText class="form-control" @bind-Value="ViewModel.EditBusiness.PhoneNumber" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Website</label>
                        <InputText type="url" class="form-control" @bind-Value="ViewModel.EditBusiness.Website" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">Update</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => ViewModel.CancelEdit()">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Tax ID</th>
                    <th>Type</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Website</th>
                    <th>Addresses</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var business in ViewModel.Businesses)
                {
                    <tr>
                        <td>@business.Name</td>
                        <td>@business.TaxId</td>
                        <td><span class="badge bg-secondary">@business.Type</span></td>
                        <td>@business.Email</td>
                        <td>@business.PhoneNumber</td>
                        <td>
                            @if (!string.IsNullOrEmpty(business.Website))
                            {
                                <a href="@business.Website" target="_blank">@business.Website</a>
                            }
                        </td>
                        <td>
                            <span class="badge bg-info">@business.AddressIds.Count</span>
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <button class="btn btn-sm btn-outline-info" @onclick="() => ManageAddresses(business)">
                                    <i class="bi bi-geo-alt"></i> Addresses
                                </button>
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => EditBusiness(business)">
                                    <i class="bi bi-pencil"></i> Edit
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteBusiness(business.Id)">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!ViewModel.Businesses.Any())
    {
        <div class="alert alert-info">
            No businesses found. Click "Add New Business" to create one.
        </div>
    }

    @if (ViewModel.IsManagingAddresses && ViewModel.SelectedBusiness != null)
    {
        <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-xl modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Manage Addresses - @ViewModel.SelectedBusiness.Name</h5>
                        <button type="button" class="btn-close" @onclick="() => ViewModel.CancelAddressManagement()"></button>
                    </div>
                    <div class="modal-body">
                        @if (ViewModel.HasError)
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                @ViewModel.ErrorMessage
                                <button type="button" class="btn-close" @onclick="() => ViewModel.ClearError()"></button>
                            </div>
                        }

                        <div class="mb-3">
                            <button class="btn btn-primary btn-sm" @onclick="() => ViewModel.StartCreateAddress()">
                                <i class="bi bi-plus-circle"></i> Create New Address
                            </button>
                        </div>

                        @if (ViewModel.IsCreatingAddress)
                        {
                            <div class="card mb-3 border-primary">
                                <div class="card-header bg-primary text-white">
                                    <h6 class="mb-0">Create New Address</h6>
                                </div>
                                <div class="card-body">
                                    <EditForm Model="@ViewModel.NewAddress" OnValidSubmit="CreateAndAddAddress">
                                        <div class="row">
                                            <div class="col-md-12 mb-3">
                                                <label class="form-label">Street</label>
                                                <InputText class="form-control" @bind-Value="ViewModel.NewAddress.Street" />
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">City</label>
                                                <InputText class="form-control" @bind-Value="ViewModel.NewAddress.City" />
                                            </div>
                                            <div class="col-md-3 mb-3">
                                                <label class="form-label">State</label>
                                                <InputText class="form-control" @bind-Value="ViewModel.NewAddress.State" />
                                            </div>
                                            <div class="col-md-3 mb-3">
                                                <label class="form-label">Zip Code</label>
                                                <InputText class="form-control" @bind-Value="ViewModel.NewAddress.ZipCode" />
                                            </div>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Country</label>
                                            <InputText class="form-control" @bind-Value="ViewModel.NewAddress.Country" />
                                        </div>
                                        <div class="d-flex gap-2">
                                            <button type="submit" class="btn btn-success">Create & Add</button>
                                            <button type="button" class="btn btn-secondary" @onclick="() => ViewModel.IsCreatingAddress = false">Cancel</button>
                                        </div>
                                    </EditForm>
                                </div>
                            </div>
                        }

                        <div class="row">
                            <div class="col-md-6">
                                <h6>Current Addresses (@ViewModel.BusinessAddresses.Count)</h6>
                                @if (ViewModel.BusinessAddresses.Any())
                                {
                                    <div class="list-group">
                                        @foreach (var address in ViewModel.BusinessAddresses)
                                        {
                                            <div class="list-group-item">
                                                <div class="d-flex w-100 justify-content-between align-items-start">
                                                    <div>
                                                        <h6 class="mb-1">@address.Street</h6>
                                                        <p class="mb-1">@address.City, @address.State @address.ZipCode</p>
                                                        <small>@address.Country</small>
                                                    </div>
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveAddress(address.Id)">
                                                        <i class="bi bi-trash"></i> Remove
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-info">
                                        No addresses assigned to this business yet.
                                    </div>
                                }
                            </div>

                            <div class="col-md-6">
                                <h6>Available Addresses (@ViewModel.AvailableAddresses.Count)</h6>
                                @if (ViewModel.AvailableAddresses.Any())
                                {
                                    <div class="list-group">
                                        @foreach (var address in ViewModel.AvailableAddresses)
                                        {
                                            <div class="list-group-item">
                                                <div class="d-flex w-100 justify-content-between align-items-start">
                                                    <div>
                                                        <h6 class="mb-1">@address.Street</h6>
                                                        <p class="mb-1">@address.City, @address.State @address.ZipCode</p>
                                                        <small>@address.Country - Owner: @address.OwnerName</small>
                                                    </div>
                                                    <button class="btn btn-sm btn-outline-success" @onclick="() => AddExistingAddress(address.Id)">
                                                        <i class="bi bi-plus"></i> Add
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-info">
                                        No other addresses available.
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="() => ViewModel.CancelAddressManagement()">Close</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    protected override async Task OnInitializedAsync()
    {
        await ViewModel.LoadBusinessesAsync();
    }

    private void ShowCreateForm()
    {
        ViewModel.IsCreating = true;
    }

    private async Task CreateBusiness()
    {
        await ViewModel.CreateBusinessAsync();
    }

    private void EditBusiness(BusinessModel business)
    {
        ViewModel.StartEdit(business);
    }

    private async Task UpdateBusiness()
    {
        await ViewModel.UpdateBusinessAsync();
    }

    private async Task DeleteBusiness(Guid id)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this business?"))
        {
            await ViewModel.DeleteBusinessAsync(id);
        }
    }

    private async Task ManageAddresses(BusinessModel business)
    {
        await ViewModel.StartManageAddressesAsync(business);
    }

    private async Task AddExistingAddress(Guid addressId)
    {
        await ViewModel.AddExistingAddressAsync(addressId);
    }

    private async Task RemoveAddress(Guid addressId)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to remove this address?"))
        {
            await ViewModel.RemoveAddressAsync(addressId);
        }
    }

    private async Task CreateAndAddAddress()
    {
        await ViewModel.CreateAndAddAddressAsync();
    }

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = default!;
}
