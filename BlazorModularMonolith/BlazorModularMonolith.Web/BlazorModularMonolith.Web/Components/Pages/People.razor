@page "/people"
@rendermode InteractiveServer
@inject PeopleViewModel ViewModel
@using BlazorModularMonolith.Web.ViewModels
@using BlazorModularMonolith.Web.Models

<PageTitle>People Management</PageTitle>

<h1>People Management</h1>

@if (ViewModel.HasError)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @ViewModel.ErrorMessage
        <button type="button" class="btn-close" @onclick="() => ViewModel.ClearError()"></button>
    </div>
}

@if (ViewModel.IsBusy)
{
    <div class="text-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="mb-3">
        <button class="btn btn-primary" @onclick="ShowCreateForm">
            <i class="bi bi-plus-circle"></i> Add New Person
        </button>
    </div>

    @if (ViewModel.IsCreating)
    {
        <div class="card mb-3">
            <div class="card-header">
                <h5>Create New Person</h5>
            </div>
            <div class="card-body">
                <EditForm Model="@ViewModel.NewPerson" OnValidSubmit="CreatePerson">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">First Name</label>
                            <InputText class="form-control" @bind-Value="ViewModel.NewPerson.FirstName" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Last Name</label>
                            <InputText class="form-control" @bind-Value="ViewModel.NewPerson.LastName" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <InputText type="email" class="form-control" @bind-Value="ViewModel.NewPerson.Email" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Phone Number</label>
                            <InputText class="form-control" @bind-Value="ViewModel.NewPerson.PhoneNumber" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Date of Birth</label>
                        <InputDate class="form-control" @bind-Value="ViewModel.NewPerson.DateOfBirth" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">Save</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => ViewModel.CancelEdit()">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @if (ViewModel.IsEditing && ViewModel.SelectedPerson != null)
    {
        <div class="card mb-3">
            <div class="card-header">
                <h5>Edit Person</h5>
            </div>
            <div class="card-body">
                <EditForm Model="@ViewModel.EditPerson" OnValidSubmit="UpdatePerson">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">First Name</label>
                            <InputText class="form-control" @bind-Value="ViewModel.EditPerson.FirstName" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Last Name</label>
                            <InputText class="form-control" @bind-Value="ViewModel.EditPerson.LastName" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <InputText type="email" class="form-control" @bind-Value="ViewModel.EditPerson.Email" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Phone Number</label>
                            <InputText class="form-control" @bind-Value="ViewModel.EditPerson.PhoneNumber" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Date of Birth</label>
                        <InputDate class="form-control" @bind-Value="ViewModel.EditPerson.DateOfBirth" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">Update</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => ViewModel.CancelEdit()">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Date of Birth</th>
                    <th>Addresses</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var person in ViewModel.People)
                {
                    <tr>
                        <td>@person.FullName</td>
                        <td>@person.Email</td>
                        <td>@person.PhoneNumber</td>
                        <td>@person.DateOfBirth.ToShortDateString()</td>
                        <td>
                            <span class="badge bg-info">@person.AddressIds.Count</span>
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => EditPerson(person)">
                                    <i class="bi bi-pencil"></i> Edit
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeletePerson(person.Id)">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!ViewModel.People.Any())
    {
        <div class="alert alert-info">
            No people found. Click "Add New Person" to create one.
        </div>
    }
}

@code {
    protected override async Task OnInitializedAsync()
    {
        await ViewModel.LoadPeopleAsync();
    }

    private void ShowCreateForm()
    {
        ViewModel.IsCreating = true;
    }

    private async Task CreatePerson()
    {
        await ViewModel.CreatePersonAsync();
    }

    private void EditPerson(PersonModel person)
    {
        ViewModel.StartEdit(person);
    }

    private async Task UpdatePerson()
    {
        await ViewModel.UpdatePersonAsync();
    }

    private async Task DeletePerson(Guid id)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this person?"))
        {
            await ViewModel.DeletePersonAsync(id);
        }
    }

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = default!;
}
