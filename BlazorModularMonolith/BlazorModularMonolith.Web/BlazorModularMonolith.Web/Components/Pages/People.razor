@page "/people"
@rendermode InteractiveServer
@inject PeopleViewModel ViewModel
@inject IAddressApiService AddressService
@using BlazorModularMonolith.Web.ViewModels
@using BlazorModularMonolith.Web.Models
@using BlazorModularMonolith.Web.Services

<PageTitle>People Management</PageTitle>

<AuthorizeView>
<h1>People Management</h1>

@if (ViewModel.HasError)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @ViewModel.ErrorMessage
        <button type="button" class="btn-close" @onclick="() => ViewModel.ClearError()"></button>
    </div>
}

@if (ViewModel.IsBusy)
{
    <div class="text-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="mb-3">
        <button class="btn btn-primary" @onclick="ShowCreateForm">
            <i class="bi bi-plus-circle"></i> Add New Person
        </button>
    </div>

    @if (ViewModel.IsCreating)
    {
        <div class="card mb-3">
            <div class="card-header">
                <h5>Create New Person</h5>
            </div>
            <div class="card-body">
                <EditForm Model="@ViewModel.NewPerson" OnValidSubmit="CreatePerson">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">First Name</label>
                            <InputText class="form-control" @bind-Value="ViewModel.NewPerson.FirstName" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Last Name</label>
                            <InputText class="form-control" @bind-Value="ViewModel.NewPerson.LastName" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <InputText type="email" class="form-control" @bind-Value="ViewModel.NewPerson.Email" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Phone Number</label>
                            <InputText class="form-control" @bind-Value="ViewModel.NewPerson.PhoneNumber" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Date of Birth</label>
                        <InputDate class="form-control" @bind-Value="ViewModel.NewPerson.DateOfBirth" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">Save</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => ViewModel.CancelEdit()">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @if (ViewModel.IsEditing && ViewModel.SelectedPerson != null)
    {
        <div class="card mb-3">
            <div class="card-header">
                <h5>Edit Person</h5>
            </div>
            <div class="card-body">
                <EditForm Model="@ViewModel.EditPerson" OnValidSubmit="UpdatePerson">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">First Name</label>
                            <InputText class="form-control" @bind-Value="ViewModel.EditPerson.FirstName" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Last Name</label>
                            <InputText class="form-control" @bind-Value="ViewModel.EditPerson.LastName" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <InputText type="email" class="form-control" @bind-Value="ViewModel.EditPerson.Email" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Phone Number</label>
                            <InputText class="form-control" @bind-Value="ViewModel.EditPerson.PhoneNumber" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Date of Birth</label>
                        <InputDate class="form-control" @bind-Value="ViewModel.EditPerson.DateOfBirth" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">Update</button>
                        <button type="button" class="btn btn-secondary" @onclick="() => ViewModel.CancelEdit()">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Date of Birth</th>
                    <th>Addresses</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var person in ViewModel.People)
                {
                    <tr>
                        <td>@person.FullName</td>
                        <td>@person.Email</td>
                        <td>@person.PhoneNumber</td>
                        <td>@person.DateOfBirth.ToShortDateString()</td>
                        <td>
                            <span class="badge bg-info">@person.AddressIds.Count</span>
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <button class="btn btn-sm btn-outline-info" @onclick="() => ManageAddresses(person)">
                                    <i class="bi bi-geo-alt"></i> Addresses
                                </button>
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => EditPerson(person)">
                                    <i class="bi bi-pencil"></i> Edit
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeletePerson(person.Id)">
                                    <i class="bi bi-trash"></i> Delete
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!ViewModel.People.Any())
    {
        <div class="alert alert-info">
            No people found. Click "Add New Person" to create one.
        </div>
    }

    @if (ViewModel.IsManagingAddresses && ViewModel.SelectedPerson != null)
    {
        <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
            <div class="modal-dialog modal-xl modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Manage Addresses - @ViewModel.SelectedPerson.FullName</h5>
                        <button type="button" class="btn-close" @onclick="() => ViewModel.CancelAddressManagement()"></button>
                    </div>
                    <div class="modal-body">
                        @if (ViewModel.HasError)
                        {
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                @ViewModel.ErrorMessage
                                <button type="button" class="btn-close" @onclick="() => ViewModel.ClearError()"></button>
                            </div>
                        }

                        <div class="mb-3">
                            <button class="btn btn-primary btn-sm" @onclick="() => ViewModel.StartCreateAddress()">
                                <i class="bi bi-plus-circle"></i> Create New Address
                            </button>
                        </div>

                        @if (ViewModel.IsCreatingAddress)
                        {
                            <div class="card mb-3 border-primary">
                                <div class="card-header bg-primary text-white">
                                    <h6 class="mb-0">Create New Address</h6>
                                </div>
                                <div class="card-body">
                                    <EditForm Model="@ViewModel.NewAddress" OnValidSubmit="CreateAndAddAddress">
                                        <div class="row">
                                            <div class="col-md-12 mb-3">
                                                <label class="form-label">Street</label>
                                                <InputText class="form-control" @bind-Value="ViewModel.NewAddress.Street" />
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label">City</label>
                                                <InputText class="form-control" @bind-Value="ViewModel.NewAddress.City" />
                                            </div>
                                            <div class="col-md-3 mb-3">
                                                <label class="form-label">State</label>
                                                <InputText class="form-control" @bind-Value="ViewModel.NewAddress.State" />
                                            </div>
                                            <div class="col-md-3 mb-3">
                                                <label class="form-label">Zip Code</label>
                                                <InputText class="form-control" @bind-Value="ViewModel.NewAddress.ZipCode" />
                                            </div>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Country</label>
                                            <InputText class="form-control" @bind-Value="ViewModel.NewAddress.Country" />
                                        </div>
                                        <div class="d-flex gap-2">
                                            <button type="submit" class="btn btn-success">Create & Add</button>
                                            <button type="button" class="btn btn-secondary" @onclick="() => ViewModel.IsCreatingAddress = false">Cancel</button>
                                        </div>
                                    </EditForm>
                                </div>
                            </div>
                        }

                        <div class="row">
                            <div class="col-md-6">
                                <h6>Current Addresses (@ViewModel.PersonAddresses.Count)</h6>
                                @if (ViewModel.PersonAddresses.Any())
                                {
                                    <div class="list-group">
                                        @foreach (var address in ViewModel.PersonAddresses)
                                        {
                                            <div class="list-group-item">
                                                <div class="d-flex w-100 justify-content-between align-items-start">
                                                    <div>
                                                        <h6 class="mb-1">@address.Street</h6>
                                                        <p class="mb-1">@address.City, @address.State @address.ZipCode</p>
                                                        <small>@address.Country</small>
                                                    </div>
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveAddress(address.Id)">
                                                        <i class="bi bi-trash"></i> Remove
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-info">
                                        No addresses assigned to this person yet.
                                    </div>
                                }
                            </div>

                            <div class="col-md-6">
                                <h6>Available Addresses (@ViewModel.AvailableAddresses.Count)</h6>
                                @if (ViewModel.AvailableAddresses.Any())
                                {
                                    <div class="list-group">
                                        @foreach (var address in ViewModel.AvailableAddresses)
                                        {
                                            <div class="list-group-item">
                                                <div class="d-flex w-100 justify-content-between align-items-start">
                                                    <div>
                                                        <h6 class="mb-1">@address.Street</h6>
                                                        <p class="mb-1">@address.City, @address.State @address.ZipCode</p>
                                                        <small>@address.Country - Owner: @address.OwnerName</small>
                                                    </div>
                                                    <button class="btn btn-sm btn-outline-success" @onclick="() => AddExistingAddress(address.Id)">
                                                        <i class="bi bi-plus"></i> Add
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-info">
                                        No other addresses available.
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="() => ViewModel.CancelAddressManagement()">Close</button>
                    </div>
                </div>
            </div>
        </div>
    }
}
</AuthorizeView>

@code {
    protected override async Task OnInitializedAsync()
    {
        await ViewModel.LoadPeopleAsync();
    }

    private void ShowCreateForm()
    {
        ViewModel.IsCreating = true;
    }

    private async Task CreatePerson()
    {
        await ViewModel.CreatePersonAsync();
    }

    private void EditPerson(PersonModel person)
    {
        ViewModel.StartEdit(person);
    }

    private async Task UpdatePerson()
    {
        await ViewModel.UpdatePersonAsync();
    }

    private async Task DeletePerson(Guid id)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this person?"))
        {
            await ViewModel.DeletePersonAsync(id);
        }
    }

    private async Task ManageAddresses(PersonModel person)
    {
        await ViewModel.StartManageAddressesAsync(person);
    }

    private async Task AddExistingAddress(Guid addressId)
    {
        await ViewModel.AddExistingAddressAsync(addressId);
    }

    private async Task RemoveAddress(Guid addressId)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to remove this address?"))
        {
            await ViewModel.RemoveAddressAsync(addressId);
        }
    }

    private async Task CreateAndAddAddress()
    {
        await ViewModel.CreateAndAddAddressAsync();
    }

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = default!;
}
