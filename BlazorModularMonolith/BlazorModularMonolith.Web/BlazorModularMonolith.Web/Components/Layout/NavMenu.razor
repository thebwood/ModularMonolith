@using BlazorModularMonolith.Web.Services
@using BlazorModularMonolith.Web.Models
@inject IAuthService AuthService
@inject NavigationManager Navigation

<nav class="nav-menu">
    <div class="nav-section">
        <span class="nav-section-label">Main</span>
        <NavLink class="sidebar-link" href="" Match="NavLinkMatch.All">
            <i class="bi bi-house-fill sidebar-link-icon"></i>
            <span>Home</span>
        </NavLink>
    </div>

    @if (_isAuthenticated)
    {
        <div class="nav-section">
            <span class="nav-section-label">Data</span>
            <NavLink class="sidebar-link" href="people">
                <i class="bi bi-people-fill sidebar-link-icon"></i>
                <span>People</span>
            </NavLink>
            <NavLink class="sidebar-link" href="businesses">
                <i class="bi bi-building sidebar-link-icon"></i>
                <span>Businesses</span>
            </NavLink>
        </div>

        @if (_isAdmin)
        {
            <div class="nav-section">
                <span class="nav-section-label">Admin</span>
                <NavLink class="sidebar-link" href="users">
                    <i class="bi bi-person-gear sidebar-link-icon"></i>
                    <span>User Management</span>
                </NavLink>
            </div>
        }
    }
    else
    {
        <div class="nav-section">
            <span class="nav-section-label">Account</span>
            <NavLink class="sidebar-link" href="login">
                <i class="bi bi-box-arrow-in-right sidebar-link-icon"></i>
                <span>Login</span>
            </NavLink>
            <NavLink class="sidebar-link" href="register">
                <i class="bi bi-person-plus sidebar-link-icon"></i>
                <span>Register</span>
            </NavLink>
        </div>
    }

    <div class="nav-footer">
        <NavLink class="sidebar-link sidebar-link--sm" href="about">
            <i class="bi bi-info-circle sidebar-link-icon"></i>
            <span>About</span>
        </NavLink>

        @if (_isAuthenticated && _currentUser != null)
        {
            <div class="user-footer">
                <div class="user-footer-info">
                    <div class="user-footer-avatar">
                        @(_currentUser.Username.Length > 0 ? _currentUser.Username[0].ToString().ToUpper() : "?")
                    </div>
                    <div class="user-footer-details">
                        <span class="user-footer-name">@_currentUser.Username</span>
                        @if (_isAdmin)
                        {
                            <span class="role-pill role-pill--admin">Admin</span>
                        }
                        else
                        {
                            <span class="role-pill role-pill--user">User</span>
                        }
                    </div>
                </div>
                <button class="user-footer-logout" @onclick="HandleLogout">
                    <i class="bi bi-box-arrow-right"></i> Sign Out
                </button>
            </div>
        }
    </div>
</nav>

<style>
    .nav-menu {
        display: flex;
        flex-direction: column;
        padding: 0.75rem 0 0;
        flex: 1;
        overflow-y: auto;
        min-height: 0;
    }

    .nav-section {
        display: flex;
        flex-direction: column;
        margin-bottom: 0.25rem;
    }

    .nav-section-label {
        display: block;
        padding: 0.5rem 1.25rem 0.25rem;
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.09em;
        color: rgba(255, 255, 255, 0.4);
    }

    /* ── Sidebar links ── */
    .sidebar-link {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 0.75rem;
        margin: 0.1rem 0.75rem;
        padding: 0.6rem 0.9rem;
        color: rgba(255, 255, 255, 0.78);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        border-radius: 0.45rem;
        transition: background 0.15s ease, color 0.15s ease;
        white-space: nowrap;
    }

    .sidebar-link:hover {
        background: rgba(255, 255, 255, 0.12);
        color: #fff;
        text-decoration: none;
    }

    .sidebar-link.active {
        background: rgba(167, 139, 250, 0.28);
        color: #d8b4fe;
        font-weight: 600;
    }

    .sidebar-link--sm {
        font-size: 0.82rem;
        padding: 0.45rem 0.9rem;
        color: rgba(255, 255, 255, 0.5);
    }

    .sidebar-link--sm:hover {
        color: rgba(255, 255, 255, 0.85);
    }

    .sidebar-link-icon {
        font-size: 1rem;
        width: 1.1rem;
        text-align: center;
        flex-shrink: 0;
        opacity: 0.85;
    }

    .sidebar-link:hover .sidebar-link-icon,
    .sidebar-link.active .sidebar-link-icon {
        opacity: 1;
    }

    /* ── Footer (About + User section) ── */
    .nav-footer {
        margin-top: auto;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        padding: 0.75rem 0 0.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    /* ── User footer section ── */
    .user-footer {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin: 0.25rem 0.75rem 0.25rem;
        padding: 0.65rem 0.75rem;
        background: rgba(255, 255, 255, 0.07);
        border-radius: 0.6rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .user-footer-info {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .user-footer-avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        background: linear-gradient(135deg, #818cf8 0%, #a78bfa 100%);
        color: #fff;
        font-size: 0.85rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .user-footer-details {
        display: flex;
        flex-direction: column;
        min-width: 0;
        line-height: 1.3;
    }

    .user-footer-name {
        font-size: 0.85rem;
        font-weight: 600;
        color: #fff;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .role-pill {
        display: inline-block;
        font-size: 0.6rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        padding: 0.08rem 0.4rem;
        border-radius: 0.25rem;
    }

    .role-pill--admin {
        background: rgba(252, 165, 165, 0.25);
        color: #fca5a5;
    }

    .role-pill--user {
        background: rgba(147, 197, 253, 0.2);
        color: #93c5fd;
    }

    .user-footer-logout {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.45rem;
        padding: 0.45rem 0.75rem;
        background: rgba(239, 68, 68, 0.18);
        border: 1px solid rgba(239, 68, 68, 0.35);
        border-radius: 0.4rem;
        color: #fca5a5;
        font-size: 0.82rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.15s, color 0.15s, border-color 0.15s;
        white-space: nowrap;
    }

    .user-footer-logout:hover {
        background: rgba(239, 68, 68, 0.35);
        color: #fee2e2;
        border-color: rgba(239, 68, 68, 0.6);
    }
</style>

@code {
    private bool _isAuthenticated;
    private bool _isAdmin;
    private UserInfo? _currentUser;

    protected override async Task OnInitializedAsync()
    {
        await RefreshState();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RefreshState();
            StateHasChanged();
        }
    }

    private async Task RefreshState()
    {
        _isAuthenticated = await AuthService.IsAuthenticatedAsync();
        _isAdmin = _isAuthenticated && await AuthService.IsInRoleAsync("Admin");
        if (_isAuthenticated)
            _currentUser = await AuthService.GetCurrentUserAsync();
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
