@using BlazorModularMonolith.Web.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation

<div class="ld-container">
    @if (_isAuthenticated && _userInfo != null)
    {
        <div class="ld-user-pill">
            <div class="ld-avatar">@(_userInfo.Username.Length > 0 ? _userInfo.Username[0].ToString().ToUpper() : "?")</div>
            <div class="ld-user-info">
                <span class="ld-username">@_userInfo.Username</span>
                @if (_userInfo.Roles.Contains("Admin"))
                {
                    <span class="ld-role ld-role--admin">Admin</span>
                }
                else
                {
                    <span class="ld-role ld-role--user">User</span>
                }
            </div>
            <button class="ld-logout-btn" @onclick="HandleLogout" title="Sign out">
                <i class="bi bi-box-arrow-right"></i>
                <span class="ld-logout-label">Sign out</span>
            </button>
        </div>
    }
    else
    {
        <div class="ld-auth-links">
            <a href="/login" class="ld-btn-login">
                <i class="bi bi-box-arrow-in-right"></i> Login
            </a>
            <a href="/register" class="ld-btn-register">
                <i class="bi bi-person-plus"></i> Register
            </a>
        </div>
    }
</div>

<style>
    .ld-container {
        display: flex;
        align-items: center;
    }

    /* ── Authenticated: pill widget ── */
    .ld-user-pill {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        background: #f4f6fb;
        border: 1px solid #e3e6f0;
        border-radius: 2rem;
        padding: 0.3rem 0.5rem 0.3rem 0.4rem;
    }

    .ld-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        color: #fff;
        font-size: 0.8rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .ld-user-info {
        display: flex;
        flex-direction: column;
        line-height: 1.2;
        max-width: 110px;
    }

    .ld-username {
        font-size: 0.85rem;
        font-weight: 600;
        color: #1f2937;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .ld-role {
        font-size: 0.62rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 0.05rem 0.35rem;
        border-radius: 0.2rem;
        align-self: flex-start;
    }

    .ld-role--admin {
        background: #fee2e2;
        color: #b91c1c;
    }

    .ld-role--user {
        background: #dbeafe;
        color: #1d4ed8;
    }

    .ld-logout-btn {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        background: none;
        border: 1px solid #e3e6f0;
        color: #6b7280;
        cursor: pointer;
        padding: 0.3rem 0.6rem;
        font-size: 0.82rem;
        font-weight: 500;
        border-radius: 1.5rem;
        transition: background 0.15s, color 0.15s, border-color 0.15s;
        white-space: nowrap;
    }

    .ld-logout-btn:hover {
        background: #fee2e2;
        color: #dc2626;
        border-color: #fca5a5;
    }

    .ld-logout-btn i {
        font-size: 0.9rem;
    }

    @@media (max-width: 767.98px) {
        .ld-user-info { display: none; }
        .ld-logout-label { display: none; }
    }

    /* ── Unauthenticated ── */
    .ld-auth-links {
        display: flex;
        gap: 0.5rem;
        align-items: center;
    }

    .ld-btn-login, .ld-btn-register {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.35rem 0.85rem;
        font-size: 0.85rem;
        font-weight: 500;
        border-radius: 0.4rem;
        text-decoration: none;
        transition: background 0.15s, color 0.15s, border-color 0.15s;
    }

    .ld-btn-login {
        border: 1px solid #d1d5db;
        color: #374151;
        background: #fff;
    }

    .ld-btn-login:hover {
        background: #f4f6fb;
        color: #111827;
        border-color: #9ca3af;
        text-decoration: none;
    }

    .ld-btn-register {
        background: #4f46e5;
        color: #fff;
        border: 1px solid #4f46e5;
    }

    .ld-btn-register:hover {
        background: #4338ca;
        border-color: #4338ca;
        color: #fff;
        text-decoration: none;
    }
</style>

@code {
    private bool _isAuthenticated;
    private Models.UserInfo? _userInfo;

    protected override async Task OnInitializedAsync()
    {
        await CheckAuthentication();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CheckAuthentication();
            StateHasChanged();
        }
    }

    private async Task CheckAuthentication()
    {
        _isAuthenticated = await AuthService.IsAuthenticatedAsync();
        if (_isAuthenticated)
            _userInfo = await AuthService.GetCurrentUserAsync();
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
